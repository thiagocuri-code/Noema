generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Student {
  id        String   @id @default(cuid())
  googleId  String   @unique
  name      String
  email     String   @unique
  image     String?
  createdAt DateTime @default(now())

  profile           StudentProfile?
  performances      Performance[]
  interactions      AiInteraction[]
  studyInteractions StudyInteraction[]
  examSessions      ExamSession[]
}

model StudentProfile {
  id             String   @id @default(cuid())
  studentId      String   @unique
  learningStyle  String
  goal           String
  hardSubject    String
  helpPreference String
  studyTime      String
  feedbackStyle  String
  schoolYear     String
  completedAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model Performance {
  id           String   @id @default(cuid())
  studentId    String
  courseId     String
  courseName   String
  activityName String
  score        Float
  feedback     String
  submittedAt  DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model AiInteraction {
  id          String   @id @default(cuid())
  studentId   String
  courseId    String
  courseName  String
  prompt      String
  response    String
  fingerprint String
  createdAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model StudyInteraction {
  id         String   @id @default(cuid())
  studentId  String
  courseId   String
  courseName String
  type       String   // "darwin" | "revisao" | "simulado"
  metadata   Json?
  createdAt  DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model ExamSession {
  id                 String   @id @default(cuid())
  studentId          String
  courseId           String
  courseName         String
  title              String
  examDate           DateTime?
  fileIds            String[]
  fileTitles         String[]
  contextSnapshot    String   // full concatenated source text
  topicsWeak         String[] // topics student struggled with
  topicsStrong       String[] // topics student mastered
  topicsReviewed     String[] // topics reviewed via study sessions
  diagnosticScore    Float?   // 0-100, baseline
  diagnosticAnswers  Json?    // raw diagnostic answers for audit
  simuladoScores     Float[]  // history of simulado scores
  revisionCount      Int      @default(0)
  flashcardsStudied  Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

model KnowledgeBase {
  id        String   @id @default(cuid())
  grade     Int
  subject   String
  title     String
  content   String
  createdAt DateTime @default(now())

  @@index([grade, subject])
}
